{
  "versionGroups": [
    {
      "label": "Workspace packages use '*' by convention (change to 'workspace:*' for pnpm/yarn)",
      "packages": ["**"],
      "dependencies": ["__ORG_SCOPE__/**"],
      "dependencyTypes": ["prod", "dev", "peer"],
      "pinVersion": "*"
    }
  ],
  "semverGroups": [
    {
      "label": "Use caret ranges for third-party dependencies",
      "packages": ["**"],
      "dependencies": ["**"],
      "dependencyTypes": ["prod", "dev"],
      "range": "^"
    }
  ],
  "sortFirst": [
    "name", "version", "description", "type", "main", "types",
    "exports", "scripts", "dependencies", "devDependencies", "peerDependencies"
  ]
}
